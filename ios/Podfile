platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'

      # NUCLEAR FIX: Remove -G from every build setting value
      config.build_settings.each do |key, value|
        if value.is_a?(String) && value.include?('-G')
          puts "[STR_APP] STRIPPING -G from #{target.name} > #{config.name} > #{key}"
          cleaned = value.gsub(/-G/, '').gsub(/  +/, ' ').strip
          config.build_settings[key] = cleaned
        elsif value.is_a?(Array) && value.any? { |v| v.include?('-G') }
          puts "[STR_APP] STRIPPING -G from #{target.name} > #{config.name} > #{key}"
          cleaned = value.map { |v| v.include?('-G') ? v.gsub(/-G/, '').gsub(/  +/, ' ').strip : v }.reject(&:empty?)
          config.build_settings[key] = cleaned
        end
      end
    end
  end

  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
  end

  # NUCLEAR FIX: Patch every generated xcconfig file on disk
  ios_dir = File.dirname(__FILE__)
  xcconfig_files = Dir.glob(File.join(ios_dir, 'Pods', '**', '*.xcconfig'))
  puts "[STR_APP] Scanning #{xcconfig_files.length} xcconfig files for -G"
  xcconfig_files.each do |file|
    next unless File.exist?(file)
    content = File.read(file)
    if content.include?('-G')
      puts "[STR_APP] PATCHING -G in #{file}"
      content = content.gsub(/-G/, '').gsub(/  +/, ' ')
      File.write(file, content)
    end
  end
end