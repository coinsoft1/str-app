require 'xcodeproj'

platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Fix for BoringSSL-GRPC "-G" flag error on newer Xcode toolchains.
    # BoringSSL-GRPC sets a per-file compiler flag "-GCC_WARN_INHIBIT_ALL_WARNINGS"
    # which newer clang misreads as "-G" and rejects.
    if target.name == 'BoringSSL-GRPC'
      target.source_build_phase.files.each do |file|
        if file.settings && file.settings['COMPILER_FLAGS']
          flags = file.settings['COMPILER_FLAGS'].split(' ')
          flags.reject! { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' }
          file.settings['COMPILER_FLAGS'] = flags.join(' ')
        end
      end
    end

    target.build_configurations.each do |config|
      # Force iOS 14.0 on every target, overriding Firebase's 10.0
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'

      # Remove the -G flag from compiler and linker settings
      ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS', 'OTHER_LDFLAGS'].each do |key|
        value = config.build_settings[key]
        if value.is_a?(String)
          cleaned = value.split(' ').reject { |f| f == '-G' }.join(' ')
          config.build_settings[key] = cleaned
        elsif value.is_a?(Array)
          config.build_settings[key] = value.reject { |f| f == '-G' }
        end
      end

      # Allow plugins like firebase_storage to import plain (non-modular)
      # headers such as Firebase.h from inside a framework module. Newer
      # Xcode enforces stricter module boundary checks by default; this
      # setting relaxes that specific check, which is the standard fix for
      # this well-known Flutter + Firebase + use_frameworks! combination.
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end

  # Also force the main Pods project configs to 14.0
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
  end

  # Patch the "template argument list" Clang parse error in basic_seq.h.
  # This file is vendored separately by BOTH gRPC-Core and gRPC-C++, so both
  # copies need the same fix. Each patch only applies if the old pattern is
  # still present, so this is a no-op (and harmless) once either pod
  # upstream-fixes the issue in a future release.
  ['gRPC-Core', 'gRPC-C++'].each do |pod_name|
    grpc_seq_file = File.join(installer.sandbox.root, pod_name, 'src', 'core', 'lib', 'promise', 'detail', 'basic_seq.h')
    if File.exist?(grpc_seq_file)
      content = File.read(grpc_seq_file)
      patched = content.gsub('Traits::template CallSeqFactory(', 'Traits::template CallSeqFactory<>(')
      if patched != content
        File.write(grpc_seq_file, patched)
      end
    end
  end

  # Also apply the "allow non-modular includes" setting directly to the main
  # Runner.xcodeproj (not just the Pods project). Some Firebase-related
  # "non-modular header" errors only clear once this setting exists on BOTH
  # the Pods project AND the main app project/target. This only adds one
  # build setting to Runner's existing configs — it does not add, remove, or
  # reorder any files, targets, or other settings, so nothing else about the
  # Xcode project changes.
  runner_project_path = File.join(__dir__, 'Runner.xcodeproj')
  if File.exist?(runner_project_path)
    runner_project = Xcodeproj::Project.open(runner_project_path)
    runner_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end
    runner_project.save
  end
end