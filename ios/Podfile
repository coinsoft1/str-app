platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'

      # DEFINITIVE FIX: Strip -G from every build setting value
      config.build_settings.each do |key, value|
        if value.is_a?(String) && value.include?('-G')
          puts "[STR_APP] Removing -G from #{target.name} > #{config.name} > #{key}"
          cleaned = value.gsub(/(\s|^)-G(\s|$)/, ' ')
                         .gsub(/-G\s+/, ' ')
                         .gsub(/\s+-G/, ' ')
                         .strip
          config.build_settings[key] = cleaned
        elsif value.is_a?(Array) && value.include?('-G')
          puts "[STR_APP] Removing -G from #{target.name} > #{config.name} > #{key}"
          config.build_settings[key] = value.reject { |v| v == '-G' }
        end
      end
    end
  end

  # Force project-level deployment target to 14.0
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
  end

  # Also patch every generated .xcconfig file on disk
  xcconfig_files = Dir.glob(File.join('Pods', '**', '*.xcconfig'))
  xcconfig_files.each do |file|
    next unless File.exist?(file)
    content = File.read(file)
    original = content.dup

    content = content.gsub(/(\s|^)-G(\s|$)/, ' ')
                     .gsub(/-G\s+/, ' ')
                     .gsub(/\s+-G/, ' ')
                     .gsub('DT_TOOLCHAIN_DIR', 'TOOLCHAIN_DIR')

    if content != original
      puts "[STR_APP] Patching xcconfig: #{file}"
      File.write(file, content)
    end
  end
end